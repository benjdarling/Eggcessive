# Single particle quad extending along local Z.
# Authored at a 4:1 length-to-width ratio for particle rendering.
# UV V runs along the beam so the light-beam texture follows its length.
o mesh_lightbeam_cross

v -0.5 0.0 -2.0
v  0.5 0.0 -2.0
v  0.5 0.0  2.0
v -0.5 0.0  2.0

vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

vn 0.0 1.0 0.0

f 1/1/1 3/3/1 2/2/1
f 1/1/1 4/4/1 3/3/1
